# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temp/debug files
v4_patch*.txt
_*.js
*.bak
nul

# Premium pattern source files (internal only — must NOT be in public/)
/scripts/patterns/

# translate-cross 체크포인트 (런타임 임시)
/scripts/.translate-checkpoint/
/scripts/.translate-checkpoint-v3/
/scripts/.pattern-data-original.js
/public/all_patterns_full.txt

# Claude Code local configs
/.claude/launch.json
/public/.claude/

# Local dev artifacts
/public/animals/animals-icon.zip
/public/animals-icon/*.zip
